rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == 'ES5QVs4PupZ2oo5QpDeY46txEEC3' ||
        request.auth.token.email.lower() == 'gilesptw4321@gmail.com' ||
        request.auth.token.email.lower() == 'adminstar1@lifeisstar.com' ||
        (request.auth.token.keys().contains('email') && exists(/databases/$(database)/documents/admins/$(request.auth.token.email.lower()))) ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() < 256;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validations ---
    function isValidCategory(data) {
      return data.keys().hasAll(['name']) &&
             data.name is string && data.name.size() > 0;
    }

    function isValidProduct(data) {
      // Basic keys required
      return data.keys().hasAll(['categoryId', 'name', 'price', 'description', 'imageUrl']) &&
             data.categoryId is string &&
             data.name is string &&
             data.price is number &&
             data.description is string &&
             data.imageUrl is string &&
             (!data.keys().contains('status') || data.status in ['active', 'hidden', 'Hidden', 'Active']) &&
             (!data.keys().contains('createdAt') || data.createdAt is timestamp || data.createdAt == null) &&
             (!data.keys().contains('updatedAt') || data.updatedAt is timestamp || data.updatedAt == null);
    }

    function isValidLinks(data) {
      return (!data.keys().contains('tokopedia') || data.tokopedia is string) &&
             (!data.keys().contains('shopee') || data.shopee is string) &&
             (!data.keys().contains('blibli') || data.blibli is string);
    }

    function isValidProfile(data) {
      return data.keys().hasAll(['title', 'content']) &&
             data.title is string && data.content is string;
    }

    function isValidTestimonial(data) {
      return data.keys().hasAll(['name', 'content', 'rating']) &&
             data.name is string &&
             data.content is string &&
             data.rating is number && data.rating >= 1 && data.rating <= 5;
    }

    function isValidSettings(data) {
      return (!data.keys().contains('mainTitle') || data.mainTitle is string) &&
             (!data.keys().contains('vision') || data.vision is string) &&
             (!data.keys().contains('mission') || data.mission is string) &&
             (!data.keys().contains('ownerName') || data.ownerName is string) &&
             (!data.keys().contains('ownerQuote') || data.ownerQuote is string) &&
             (!data.keys().contains('ownerMessage') || data.ownerMessage is string) &&
             (!data.keys().contains('ownerPhoto') || data.ownerPhoto is string) &&
             (!data.keys().contains('address') || data.address is string) &&
             (!data.keys().contains('phone') || data.phone is string) &&
             (!data.keys().contains('updatedAt') || data.updatedAt is timestamp);
    }

    // --- Rules ---

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin(); 
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin() && isValidCategory(incoming());
    }

    match /products/{productId} {
      allow list: if isAdmin() || resource.data.status == 'active';
      allow get: if true;
      allow create: if isAdmin() && isValidId(productId) && isValidProduct(incoming());
      allow update: if isAdmin() && isValidProduct(incoming());
      allow delete: if isAdmin();

      match /links/main {
        allow read: if true;
        allow write: if isAdmin() && isValidLinks(incoming());
      }
    }

    match /profile/{sectionId} {
      allow read: if true;
      allow write: if isAdmin() && isValidProfile(incoming());
    }

    match /testimonials/{testimonialId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(testimonialId) && isValidTestimonial(incoming());
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin() && isValidSettings(incoming());
    }
  }
}
