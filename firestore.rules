rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == 'ES5QVs4PupZ2oo5QpDeY46txEEC3' ||
        (request.auth.token.keys().contains('email') && request.auth.token.email.lower() == 'adminstar1@lifeisstar.com') ||
        (request.auth.token.keys().contains('email') && request.auth.token.email.lower() == 'gilesptw4321@gmail.com')
      );
    }

    function isValidId(id) {
      return id is string && id.size() < 256;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validations ---
    function isValidCategory(data) {
      return data.keys().hasAll(['name']) &&
             data.name is string;
    }

    function isValidProduct(data) {
      // Basic keys required
      return data.keys().hasAll(['categoryId', 'name', 'price', 'description', 'imageUrl']) &&
             data.categoryId is string &&
             data.name is string &&
             data.price is number &&
             data.description is string &&
             data.imageUrl is string;
    }

    function isValidLinks(data) {
      return (!data.keys().contains('tokopedia') || data.tokopedia is string) &&
             (!data.keys().contains('shopee') || data.shopee is string) &&
             (!data.keys().contains('blibli') || data.blibli is string);
    }

    function isValidProfile(data) {
      return data.keys().hasAll(['title', 'content']) &&
             data.title is string && data.content is string;
    }

    function isValidTestimonial(data) {
      return data.keys().hasAll(['name', 'content', 'rating']) &&
             data.name is string &&
             data.content is string &&
             data.rating is number && data.rating >= 1 && data.rating <= 5;
    }

    // --- Rules ---

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin(); 
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin() && isValidCategory(incoming());
    }

    match /products/{productId} {
      allow list: if isAdmin() || resource.data.status == 'active';
      allow get: if true;
      allow create: if isAdmin() && isValidId(productId) && isValidProduct(incoming());
      allow update: if isAdmin() && isValidProduct(incoming());
      allow delete: if isAdmin();

      match /links/main {
        allow read: if true;
        allow write: if isAdmin() && isValidLinks(incoming());
      }
    }

    match /profile/{sectionId} {
      allow read: if true;
      allow write: if isAdmin() && isValidProfile(incoming());
    }

    match /testimonials/{testimonialId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(testimonialId) && isValidTestimonial(incoming());
    }
  }
}
