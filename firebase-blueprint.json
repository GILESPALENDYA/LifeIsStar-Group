{
  "entities": {
    "Category": {
      "title": "Category",
      "description": "Product categories like iPhone, Laptop, Tablet",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the category" }
      },
      "required": ["name"]
    },
    "Product": {
      "title": "Product",
      "description": "Core product data",
      "type": "object",
      "properties": {
        "categoryId": { "type": "string", "description": "Reference to Category ID" },
        "name": { "type": "string", "description": "Product name" },
        "price": { "type": "number", "description": "Price in Rupiah" },
        "description": { "type": "string", "description": "Product description" },
        "imageUrl": { "type": "string", "description": "URL to the product image" },
        "status": { "type": "string", "enum": ["active", "hidden"], "description": "Visibility status" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "views": { "type": "number", "description": "Number of times the product has been viewed" },
        "stock": { "type": "number", "minimum": 0, "description": "Current stock level" }
      },
      "required": ["categoryId", "name", "price", "description", "imageUrl", "stock"]
    },
    "MarketplaceLinks": {
      "title": "MarketplaceLinks",
      "description": "Redirect links to marketplaces",
      "type": "object",
      "properties": {
        "tokopedia": { "type": "string" },
        "shopee": { "type": "string" },
        "blibli": { "type": "string" }
      }
    },
    "ProfileSection": {
      "title": "ProfileSection",
      "description": "Company profile sections",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["title", "content"]
    },
    "Settings": {
      "title": "General Settings",
      "description": "App-wide configuration settings",
      "type": "object",
      "properties": {
        "mainTitle": { "type": "string", "description": "The main title for the About section" },
        "vision": { "type": "string" },
        "mission": { "type": "string" },
        "ownerName": { "type": "string" },
        "ownerQuote": { "type": "string" },
        "ownerMessage": { "type": "string" },
        "ownerPhoto": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "settings": {
      "schema": "Settings",
      "description": "App-wide settings documents"
    },
    "categories": {
      "schema": "Category",
      "description": "List of product categories"
    },
    "products": {
      "schema": "Product",
      "description": "List of electronics products"
    },
    "products/{productId}/links": {
      "schema": "MarketplaceLinks",
      "description": "Marketplace links for a specific product (single document named 'main')"
    },
    "profile": {
      "schema": "ProfileSection",
      "description": "Company profile sections"
    }
  }
}
